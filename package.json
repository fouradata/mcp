{
  "name": "@fouradata/mcp",
  "mcpName": "ai.foura/mcp",
  "version": "0.5.0",
  "description": "Web access for AI agents - smart HTTP, rotating proxy, and full-browser tools plus six ready-made workflows.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "mcp": "bin/foura-mcp.js",
    "foura-mcp": "bin/foura-mcp.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/stdio.ts",
    "dev:http": "tsx src/http.ts",
    "start:http": "node dist/http.js",
    "test": "npm run build && npm run test:unit && npm run test:integration:stdio && npm run test:docs",
    "test:unit": "node --test --test-reporter=spec 'tests/unit/**/*.test.mjs'",
    "test:integration:stdio": "node --test --test-concurrency=1 --test-reporter=spec 'tests/integration-stdio/**/*.test.mjs'",
    "test:integration:stdio:mocked": "node --test --test-concurrency=1 --test-reporter=spec tests/integration-stdio/proxy-exit-country-contract.test.mjs tests/integration-stdio/tool-guidance-contract.test.mjs",
    "test:integration:http": "node --test --test-reporter=spec 'tests/integration-http/**/*.test.mjs'",
    "test:docs": "node --test --test-reporter=spec 'tests/docs-compliance/**/*.test.mjs'",
    "test:syntax": "node scripts/check-test-syntax.mjs",
    "test:ci": "npm run lint && npm run build && npm run test:unit && npm run test:integration:stdio:mocked && npm run test:docs && npm run test:syntax && npm run audit:tokens && npm run audit:package",
    "test:all": "npm run test && npm run test:integration:http",
    "smoke": "node tests/smoke.mjs",
    "inspector": "npx -y @modelcontextprotocol/inspector tsx src/stdio.ts",
    "lint": "tsc --noEmit",
    "audit:package": "node scripts/audit-package.mjs",
    "audit:tokens": "node scripts/audit-tokens.mjs",
    "bump": "node scripts/bump.mjs",
    "verify:release": "node scripts/verify-release-tag.mjs",
    "prepublishOnly": "npm run test:ci"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "undici": "^8.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "cursor",
    "ai-agents",
    "llm-tools",
    "foura",
    "web-scraping",
    "scraping-api",
    "rotating-proxies",
    "anti-bot",
    "browser-automation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fouradata/mcp.git"
  },
  "homepage": "https://foura.ai/mcp",
  "bugs": {
    "url": "https://github.com/fouradata/mcp/issues"
  }
}
