{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.foura/mcp",
  "description": "Web scraping for AI agents: fetch any page via proxy or full browser, past anti-bot defenses.",
  "version": "0.4.5",
  "repository": {
    "url": "https://github.com/fouradata/mcp",
    "source": "github"
  },
  "websiteUrl": "https://foura.ai/mcp",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@fouradata/mcp",
      "version": "0.4.5",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "FOURA_API_KEY",
          "description": "Your FourA API key (pk_live_...), created at https://foura.ai/dashboard/#api-keys",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.foura.ai/mcp"
    }
  ]
}
